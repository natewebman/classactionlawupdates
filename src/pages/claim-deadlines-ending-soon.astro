---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import CategoryCrossLinks from '../components/CategoryCrossLinks.astro';
import { getExpiringSettlements } from '../lib/supabase';
import { siteConfig } from '../site.config';
import { getItemList } from '../lib/structured-data';

const settlements = await getExpiringSettlements({ limit: 50 });

const pageTitle = 'Class Action Settlements Ending Soon';
const pageDescription = 'Class action settlements with claim deadlines ending in the next 14 days. File your claim before time runs out.';

const itemListSchema = getItemList({
  name: pageTitle,
  description: pageDescription,
  items: settlements.map((a, i) => ({
    position: i + 1,
    name: a.title,
    url: `https://${siteConfig.domain}/settlements/${a.slug}`,
  })),
});

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Settlements', url: '/settlements' },
  { name: 'Deadlines Ending Soon', url: '/claim-deadlines-ending-soon' },
];

// Helper: format deadline for display
function formatDeadline(deadline: string | null): { text: string; urgent: boolean; passed: boolean } | null {
  if (!deadline) return null;
  const d = new Date(deadline + 'T00:00:00');
  if (isNaN(d.getTime())) return null;
  const now = new Date();
  now.setHours(0, 0, 0, 0);
  const daysUntil = Math.ceil((d.getTime() - now.getTime()) / (1000 * 60 * 60 * 24));
  const display = d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
  if (daysUntil < 0) return { text: `Expired ${display}`, urgent: false, passed: true };
  if (daysUntil <= 14) return { text: `${display} (${daysUntil} days left)`, urgent: true, passed: false };
  if (daysUntil <= 30) return { text: `${display} (${daysUntil} days left)`, urgent: true, passed: false };
  return { text: display, urgent: false, passed: false };
}
---

<BaseLayout title={pageTitle} description={pageDescription} breadcrumbs={breadcrumbs}>
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />

  <section class="bg-white py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="mb-10">
        <a href="/settlements" class="inline-flex items-center gap-1 text-navy-600 text-sm font-medium hover:text-navy-800 mb-4">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18"/>
          </svg>
          All Settlements
        </a>
        <h1 class="text-4xl lg:text-5xl font-heading font-black text-gray-900">{pageTitle}</h1>
        <p class="text-gray-500 mt-3 text-lg max-w-3xl">
          These settlements have claim deadlines expiring within the next 14 days. Act now to file your claim before time runs out.
        </p>
        <p class="text-sm text-gray-400 mt-2">{settlements.length} {settlements.length === 1 ? 'settlement' : 'settlements'} with upcoming deadlines.</p>
      </div>

      <!-- Settlement List -->
      {settlements.length > 0 ? (
        <div class="space-y-4">
          {settlements.map((article) => {
            const deadline = formatDeadline(article.claim_deadline);
            const isSettlement = article.news_type === 'settlement' || (article.category && article.category !== 'General');
            const path = isSettlement ? `/settlements/${article.slug}` : `/news/${article.slug}`;

            return (
              <a
                href={path}
                class="group block bg-white border border-gray-200 rounded-xl p-5 sm:p-6 hover:shadow-md hover:border-gray-300 transition-all"
              >
                <div class="sm:flex sm:items-start sm:justify-between gap-4">
                  <div class="flex-1 min-w-0">
                    <h2 class="text-lg font-heading font-bold text-gray-900 group-hover:text-navy-600 transition-colors line-clamp-2">
                      {article.title}
                    </h2>
                    {article.meta_description && (
                      <p class="text-gray-500 text-sm mt-1 line-clamp-2">{article.meta_description}</p>
                    )}
                    <div class="flex flex-wrap items-center gap-3 mt-3 text-sm">
                      {article.settlement_amount && (
                        <span class="font-semibold text-gray-800">
                          <svg class="w-4 h-4 inline-block mr-1 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                          </svg>
                          {article.settlement_amount}
                        </span>
                      )}
                      {article.potential_reward && (
                        <span class="text-gray-600">Up to {article.potential_reward}</span>
                      )}
                      {article.category && (
                        <span class="px-2 py-0.5 bg-gray-100 text-gray-600 rounded-full text-xs font-medium">{article.category}</span>
                      )}
                    </div>
                  </div>

                  {deadline && !deadline.passed && (
                    <div class="mt-3 sm:mt-0 sm:text-right shrink-0">
                      <span class="text-xs text-gray-400 uppercase tracking-wide font-medium">Claim Deadline</span>
                      <p class:list={[
                        'font-semibold text-sm mt-0.5',
                        deadline.urgent ? 'text-red-600' : 'text-gray-700',
                      ]}>
                        {deadline.text}
                      </p>
                    </div>
                  )}
                </div>
              </a>
            );
          })}
        </div>
      ) : (
        <div class="text-center py-16 bg-gray-50 rounded-2xl border border-gray-100">
          <p class="text-gray-500 font-semibold text-lg">No settlements with deadlines ending soon.</p>
          <p class="text-gray-400 mt-1">Check back regularly — new deadlines appear as settlements progress.</p>
        </div>
      )}

      <!-- CTA: Browse all open settlements -->
      <div class="mt-12 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/open-class-action-settlements"
          class="inline-flex items-center gap-2 px-6 py-3 bg-navy-600 text-white font-semibold rounded-lg hover:bg-navy-700 transition-colors"
        >
          Browse All Open Settlements
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
        <a
          href="/class-action-settlements-database"
          class="inline-flex items-center gap-2 px-6 py-3 border border-gray-300 text-gray-700 font-semibold rounded-lg hover:bg-gray-50 transition-colors"
        >
          Settlement Database
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>

      <CategoryCrossLinks />
    </div>
  </section>
</BaseLayout>
