---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../site.config';
import { US_STATES } from '../lib/brand-state-extraction';

// Build state options: "All States" first, then alphabetical
const stateOptions = [
  { value: '', label: 'All States' },
  ...Object.entries(US_STATES)
    .sort(([, a], [, b]) => a.localeCompare(b))
    .map(([slug, name]) => ({ value: slug, label: name })),
];

const topics = siteConfig.signupTopics;

// Topic icons (simple SVG paths)
const topicIcons: Record<string, string> = {
  'Stocks': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2 12l5-5 4 4 7-7m0 0v4m0-4h-4" />',
  'Personal Injury': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />',
  'Product Recalls': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />',
  'Drugs & Pharmacy': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />',
  'Financial': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />',
  'Online/Privacy': '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />',
};
---

<BaseLayout title="Sign Up" description="Create a free account to receive personalized class action settlement alerts." noIndex={true}>
  <section class="bg-gray-50 min-h-[70vh] flex items-center py-12 sm:py-16">
    <div class="max-w-lg mx-auto px-4 sm:px-6 w-full">

      <!-- Step indicator -->
      <p id="step-label" class="text-sm font-medium text-gray-400 text-center mb-2">Step 1 of 2</p>

      <div class="bg-white rounded-2xl shadow-lg p-6 sm:p-8">
        <form id="signup-form" novalidate>
          <!-- ═══ Step 1: Personalize Your Alerts ═══ -->
          <div id="step-1">
            <div class="text-center mb-6">
              <h1 id="step-heading" class="text-2xl sm:text-3xl font-heading font-black text-gray-900">Personalize Your Alerts</h1>
              <p id="step-subtitle" class="text-gray-500 mt-1.5 text-sm sm:text-base">Choose what matters to you — we'll only send relevant updates.</p>
            </div>

            <!-- State dropdown -->
            <div class="mb-5">
              <label for="signup-state" class="block text-sm font-medium text-gray-700 mb-1">Your State</label>
              <select id="signup-state" name="state" class="form-input appearance-none bg-[url('data:image/svg+xml;charset=utf-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%2216%22%20height%3D%2216%22%20fill%3D%22%236b7280%22%20viewBox%3D%220%200%2016%2016%22%3E%3Cpath%20d%3D%22M4.646%206.354l3.354%203.293%203.354-3.293.646.646L8%2010.854%203.999%207l.647-.646z%22%2F%3E%3C%2Fsvg%3E')] bg-[length:1.25rem] bg-[right_0.75rem_center] bg-no-repeat pr-10 min-h-[48px]">
                {stateOptions.map((s) => (
                  <option value={s.value}>{s.label}</option>
                ))}
              </select>
            </div>

            <!-- Topic cards -->
            <div class="mb-6">
              <p class="text-sm font-medium text-gray-700 mb-2">Topics of Interest</p>
              <div class="grid grid-cols-2 gap-2.5">
                {topics.map((topic) => (
                  <label class="topic-card group relative flex items-center gap-2.5 p-3 sm:p-3.5 rounded-xl border-2 border-gray-200 cursor-pointer select-none transition-all duration-150 hover:border-navy-300 hover:bg-navy-50/40 min-h-[48px]">
                    <input type="checkbox" name="topics" value={topic}
                      class="peer sr-only" />
                    <span class="shrink-0 w-7 h-7 sm:w-8 sm:h-8 rounded-lg bg-gray-100 text-gray-500 flex items-center justify-center transition-colors peer-checked:bg-navy-600 peer-checked:text-white">
                      <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" set:html={topicIcons[topic] || ''} />
                    </span>
                    <span class="text-sm font-medium text-gray-700 leading-tight">{topic}</span>
                    <!-- Check overlay -->
                    <span class="absolute top-1.5 right-1.5 w-5 h-5 rounded-full bg-navy-600 text-white items-center justify-center hidden peer-checked:flex">
                      <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                      </svg>
                    </span>
                    <!-- Checked border style override -->
                    <span class="absolute inset-0 rounded-xl border-2 border-transparent peer-checked:border-navy-600 pointer-events-none transition-colors"></span>
                  </label>
                ))}
              </div>
            </div>

            <!-- Next button -->
            <button type="button" id="next-btn" class="w-full btn-navy text-base py-3.5 min-h-[48px]">
              Next &rarr;
            </button>
          </div>

          <!-- ═══ Step 2: Almost Done! ═══ -->
          <div id="step-2" class="hidden">
            <div class="text-center mb-6">
              <h1 class="text-2xl sm:text-3xl font-heading font-black text-gray-900">Almost Done!</h1>
              <p class="text-gray-500 mt-1.5 text-sm sm:text-base">Enter your email to start receiving free alerts.</p>
            </div>

            <!-- Back link -->
            <button type="button" id="back-btn" class="inline-flex items-center gap-1 text-sm text-navy-600 hover:text-navy-800 font-medium mb-5 min-h-[44px]">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
              </svg>
              Back
            </button>

            <!-- Name (optional) -->
            <div class="mb-4">
              <label for="signup-name" class="block text-sm font-medium text-gray-700 mb-1">
                Full Name <span class="text-gray-400 font-normal">(optional)</span>
              </label>
              <input type="text" id="signup-name" name="name" placeholder="John Doe" autocomplete="name" class="form-input min-h-[48px]" />
            </div>

            <!-- Email (required) -->
            <div class="mb-5">
              <label for="signup-email" class="block text-sm font-medium text-gray-700 mb-1">Email Address</label>
              <input type="email" id="signup-email" name="email" placeholder="john@example.com" required autocomplete="email" class="form-input min-h-[48px]" />
              <p id="email-error" class="hidden text-red-600 text-sm mt-1">Please enter a valid email address.</p>
            </div>

            <!-- Submit button -->
            <button type="submit" id="submit-btn" class="w-full btn-navy text-base py-3.5 min-h-[48px]">
              Get My Free Alerts
            </button>

            <!-- Success / error messages -->
            <div id="signup-success" class="hidden text-center py-3 px-4 bg-green-50 text-green-700 rounded-lg text-sm font-medium mt-4">
              You're subscribed! We'll send you settlement alerts.
            </div>
            <div id="signup-error" class="hidden text-center py-3 px-4 bg-red-50 text-red-700 rounded-lg text-sm font-medium mt-4">
            </div>
          </div>
        </form>

        <p class="text-center text-sm text-gray-500 mt-6">
          We'll never share your email. <a href="/unsubscribe" class="underline hover:text-gray-700">Unsubscribe</a> anytime.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<!-- Topic card checked-border style (peer-checked via Tailwind) -->
<style>
  .topic-card:has(input:checked) {
    @apply border-navy-600 bg-navy-50/60;
  }
</style>

<script>
  import { addSubscriber } from '../lib/supabase';

  // ── State abbreviation → slug mapping (for URL prepopulation) ──
  const STATE_ABBREVS: Record<string, string> = {
    'AL': 'alabama', 'AK': 'alaska', 'AZ': 'arizona', 'AR': 'arkansas',
    'CA': 'california', 'CO': 'colorado', 'CT': 'connecticut', 'DE': 'delaware',
    'FL': 'florida', 'GA': 'georgia', 'HI': 'hawaii', 'ID': 'idaho',
    'IL': 'illinois', 'IN': 'indiana', 'IA': 'iowa', 'KS': 'kansas',
    'KY': 'kentucky', 'LA': 'louisiana', 'ME': 'maine', 'MD': 'maryland',
    'MA': 'massachusetts', 'MI': 'michigan', 'MN': 'minnesota', 'MS': 'mississippi',
    'MO': 'missouri', 'MT': 'montana', 'NE': 'nebraska', 'NV': 'nevada',
    'NH': 'new-hampshire', 'NJ': 'new-jersey', 'NM': 'new-mexico', 'NY': 'new-york',
    'NC': 'north-carolina', 'ND': 'north-dakota', 'OH': 'ohio', 'OK': 'oklahoma',
    'OR': 'oregon', 'PA': 'pennsylvania', 'RI': 'rhode-island', 'SC': 'south-carolina',
    'SD': 'south-dakota', 'TN': 'tennessee', 'TX': 'texas', 'UT': 'utah',
    'VT': 'vermont', 'VA': 'virginia', 'WA': 'washington', 'WV': 'west-virginia',
    'WI': 'wisconsin', 'WY': 'wyoming', 'DC': 'district-of-columbia',
  };

  // State full name → slug (for URL prepopulation)
  const STATE_NAMES: Record<string, string> = {};
  const stateSelect = document.getElementById('signup-state') as HTMLSelectElement;
  if (stateSelect) {
    Array.from(stateSelect.options).forEach(opt => {
      if (opt.value) STATE_NAMES[opt.textContent!.toLowerCase()] = opt.value;
    });
  }

  // ── DOM refs ──
  const form = document.getElementById('signup-form') as HTMLFormElement;
  const step1 = document.getElementById('step-1') as HTMLDivElement;
  const step2 = document.getElementById('step-2') as HTMLDivElement;
  const stepLabel = document.getElementById('step-label') as HTMLParagraphElement;
  const nextBtn = document.getElementById('next-btn') as HTMLButtonElement;
  const backBtn = document.getElementById('back-btn') as HTMLButtonElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const nameInput = document.getElementById('signup-name') as HTMLInputElement;
  const emailInput = document.getElementById('signup-email') as HTMLInputElement;
  const emailError = document.getElementById('email-error') as HTMLParagraphElement;
  const successMsg = document.getElementById('signup-success') as HTMLDivElement;
  const errorMsg = document.getElementById('signup-error') as HTMLDivElement;

  // ── URL Prepopulation ──
  const params = new URLSearchParams(window.location.search);

  // State: match by abbreviation (CA) or full name (California), case-insensitive
  const stateParam = params.get('state');
  if (stateParam && stateSelect) {
    const upper = stateParam.toUpperCase();
    const lower = stateParam.toLowerCase();
    let matchedSlug = STATE_ABBREVS[upper] || STATE_NAMES[lower] || null;
    // Also try matching against slug directly (e.g., "california", "new-york")
    if (!matchedSlug) {
      const asSlug = lower.replace(/\s+/g, '-');
      if (Array.from(stateSelect.options).some(opt => opt.value === asSlug)) {
        matchedSlug = asSlug;
      }
    }
    if (matchedSlug) stateSelect.value = matchedSlug;
  }

  // Topics: comma-separated, case-insensitive match
  const topicsParam = params.get('topics');
  if (topicsParam) {
    const requested = topicsParam.split(',').map(t => t.trim().toLowerCase());
    const checkboxes = form.querySelectorAll<HTMLInputElement>('input[name="topics"]');
    checkboxes.forEach(cb => {
      if (requested.includes(cb.value.toLowerCase())) {
        cb.checked = true;
      }
    });
  }

  // Name
  const nameParam = params.get('name');
  if (nameParam && nameInput) nameInput.value = nameParam;

  // Email (short param "e")
  const emailParam = params.get('e');
  if (emailParam && emailInput) emailInput.value = emailParam;

  // ── Step Navigation ──
  function showStep(step: 1 | 2) {
    if (step === 1) {
      step1.classList.remove('hidden');
      step2.classList.add('hidden');
      stepLabel.textContent = 'Step 1 of 2';
    } else {
      step1.classList.add('hidden');
      step2.classList.remove('hidden');
      stepLabel.textContent = 'Step 2 of 2';
      // Focus email if empty, else name
      requestAnimationFrame(() => {
        if (!emailInput.value) {
          emailInput.focus();
        } else if (!nameInput.value) {
          nameInput.focus();
        }
      });
    }
    // Scroll card into view on mobile
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  nextBtn?.addEventListener('click', () => showStep(2));
  backBtn?.addEventListener('click', () => showStep(1));

  // ── Form Submission ──
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    successMsg.classList.add('hidden');
    errorMsg.classList.add('hidden');
    emailError.classList.add('hidden');

    const email = emailInput.value.trim();
    if (!email || !emailInput.validity.valid) {
      emailError.classList.remove('hidden');
      emailInput.focus();
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = 'Subscribing...';

    const formData = new FormData(form);
    const name = (formData.get('name') as string) || undefined;
    const state = (formData.get('state') as string) || undefined;
    const selectedTopics = formData.getAll('topics') as string[];

    const result = await addSubscriber({
      email,
      name,
      state,
      topics: selectedTopics.length > 0 ? selectedTopics : undefined,
      source: 'signup_page',
      utm_source: params.get('utm_source') || undefined,
      utm_campaign: params.get('utm_campaign') || undefined,
    });

    if (!result.success) {
      errorMsg.textContent = result.error || 'Something went wrong. Please try again.';
      errorMsg.classList.remove('hidden');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Get My Free Alerts';
      return;
    }

    // Success
    form.classList.add('hidden');
    successMsg.classList.remove('hidden');
    stepLabel.textContent = '';
  });
</script>
