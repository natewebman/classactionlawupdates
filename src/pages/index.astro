---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ArticleCard from '../components/ArticleCard.astro';
import SignupForm from '../components/SignupForm.astro';
import { getArticles } from '../lib/supabase';
import { getWebSite } from '../lib/structured-data';

// Fetch latest published articles for the homepage grid
const latestSettlements = await getArticles({ limit: 6 });
const latestNews = await getArticles({ newsType: 'case-filings', limit: 3 });

const websiteSchema = getWebSite();
---

<BaseLayout>
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

  <Hero />

  <!-- Top Open Class Actions -->
  <section class="bg-gray-50 py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-end justify-between mb-8">
        <div>
          <h2 class="text-3xl font-heading font-black text-gray-900">Top Open Class Actions</h2>
          <p class="text-gray-500 mt-1">Don't miss your chance to claim what you're owed.</p>
        </div>
        <a href="/settlements" class="hidden sm:inline-flex items-center gap-1 text-navy-600 font-semibold hover:text-navy-800 transition-colors">
          View All
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>

      {latestSettlements.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {latestSettlements.map((article, i) => (
            <ArticleCard
              title={article.title}
              slug={article.slug}
              category={article.category}
              metaDescription={article.meta_description}
              publishedAt={article.published_at}
              heroImage={article.hero_image}
              heroImageAlt={article.hero_image_alt}
              basePath="/settlements"
              featured={i === 0}
            />
          ))}
        </div>
      ) : (
        <div class="text-center py-16 bg-white rounded-2xl border border-gray-100">
          <svg class="w-12 h-12 text-gray-300 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
              d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
          </svg>
          <p class="text-gray-500 font-medium">No settlements published yet.</p>
          <p class="text-gray-400 text-sm mt-1">Check back soon for updates.</p>
        </div>
      )}

      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/open-class-action-settlements" class="inline-flex items-center gap-2 px-5 py-2.5 bg-navy-600 hover:bg-navy-700 text-white font-semibold rounded-lg transition-colors text-sm">
          View Open Settlements
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
        <a href="/settlements" class="inline-flex items-center gap-1 text-navy-600 font-semibold hover:text-navy-800 transition-colors text-sm">
          Browse All Settlements
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Latest News -->
  {latestNews.length > 0 && (
    <section class="bg-white py-16 lg:py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-end justify-between mb-8">
          <div>
            <h2 class="text-3xl font-heading font-black text-gray-900">Latest News</h2>
            <p class="text-gray-500 mt-1">Stay informed with the latest case filings and settlement news.</p>
          </div>
          <a href="/news" class="hidden sm:inline-flex items-center gap-1 text-navy-600 font-semibold hover:text-navy-800 transition-colors">
            All News
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {latestNews.map((article) => (
            <ArticleCard
              title={article.title}
              slug={article.slug}
              newsType={article.news_type}
              metaDescription={article.meta_description}
              publishedAt={article.published_at}
              heroImage={article.hero_image}
              heroImageAlt={article.hero_image_alt}
              basePath="/news"
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Signup Section -->
  <SignupForm />
</BaseLayout>
