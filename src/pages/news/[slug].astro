---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedArticles from '../../components/RelatedArticles.astro';
import { getArticleBySlug } from '../../lib/supabase';
import { siteConfig } from '../../site.config';
import { marked } from 'marked';

const { slug } = Astro.params;
const article = await getArticleBySlug(slug!);

if (!article) {
  return Astro.redirect('/news');
}

const publishDate = article.published_at
  ? new Date(article.published_at).toLocaleDateString('en-US', {
      month: 'long',
      day: 'numeric',
      year: 'numeric',
    })
  : null;

const displayCategory = article.category ?? article.news_type ?? 'News';
const heroImage = article.hero_image ?? null;
const heroImageAlt = article.hero_image_alt ?? null;

const structuredData: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "NewsArticle",
  "headline": article.title,
  "description": article.meta_description,
  "datePublished": article.published_at,
  "dateModified": article.updated_at,
  "publisher": {
    "@type": "Organization",
    "name": siteConfig.name,
    "url": `https://${siteConfig.domain}`
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://${siteConfig.domain}/news/${slug}`
  },
  ...(heroImage ? { "image": heroImage } : {}),
};
---

<BaseLayout title={article.title} description={article.meta_description ?? ''} ogImage={heroImage ?? undefined}>
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <article class="bg-gray-50 min-h-screen">
    <header class="bg-gradient-to-br from-navy-700 via-navy-800 to-navy-900 relative overflow-hidden">
      <div class="absolute inset-0 opacity-10">
        <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;0.4&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
      </div>
      
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10 lg:py-14 relative">
        <nav class="mb-4">
          <ol class="flex items-center gap-2 text-sm text-white/60">
            <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
            <li><span class="mx-1">/</span></li>
            <li><a href="/news" class="hover:text-white transition-colors">News</a></li>
            <li><span class="mx-1">/</span></li>
            <li class="text-white/80 truncate max-w-[200px]">{article.title}</li>
          </ol>
        </nav>

        <div class="flex flex-wrap items-center gap-3 mb-4">
          <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-white/20 text-white">
            {displayCategory}
          </span>
          {publishDate && (
            <time class="text-sm text-white/60">{publishDate}</time>
          )}
          <span class="text-sm text-white/40">•</span>
          <span class="text-sm text-white/60">By {siteConfig.shortName} Staff</span>
        </div>

        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-heading font-black text-white leading-tight">
          {article.title}
        </h1>

        {article.meta_description && (
          <p class="text-lg lg:text-xl text-white/80 mt-4 leading-relaxed">
            {article.meta_description}
          </p>
        )}
      </div>
    </header>

    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8 lg:py-12">
      {heroImage && (
        <figure class="mb-8 -mt-6">
          <img 
            src={heroImage}
            alt={heroImageAlt ?? article.title}
            class="w-full h-auto rounded-xl shadow-lg object-cover max-h-[460px]"
            loading="eager"
          />
        </figure>
      )}

      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 sm:p-8 lg:p-10">
        {article.content ? (
          <div class="prose-article text-lg" set:html={marked.parse(article.content)} />
        ) : (
          <p class="text-gray-400 italic">Article content is being prepared. Check back soon.</p>
        )}
      </div>

      <div class="mt-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <a href="/news" class="inline-flex items-center gap-2 text-navy-600 font-semibold hover:text-navy-800 transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18"/>
          </svg>
          Back to News
        </a>
        
        <div class="flex items-center gap-3">
          <span class="text-sm text-gray-500">Share:</span>
          <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(article.title)}&url=${encodeURIComponent(`https://${siteConfig.domain}/news/${slug}`)}`}
            target="_blank"
            rel="noopener"
            class="w-9 h-9 flex items-center justify-center rounded-full bg-gray-100 text-gray-600 hover:bg-navy-600 hover:text-white transition-colors"
            aria-label="Share on Twitter"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(`https://${siteConfig.domain}/news/${slug}`)}`}
            target="_blank"
            rel="noopener"
            class="w-9 h-9 flex items-center justify-center rounded-full bg-gray-100 text-gray-600 hover:bg-navy-600 hover:text-white transition-colors"
            aria-label="Share on Facebook"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href={`https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(`https://${siteConfig.domain}/news/${slug}`)}&title=${encodeURIComponent(article.title)}`}
            target="_blank"
            rel="noopener"
            class="w-9 h-9 flex items-center justify-center rounded-full bg-gray-100 text-gray-600 hover:bg-navy-600 hover:text-white transition-colors"
            aria-label="Share on LinkedIn"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        </div>
      </div>

      <div class="mt-10 bg-navy-600 rounded-xl p-6 sm:p-8 text-center">
        <h2 class="text-xl sm:text-2xl font-heading font-bold text-white mb-2">Stay Updated on Class Actions</h2>
        <p class="text-white/80 mb-4">Get notified when new settlements open that you may qualify for.</p>
        <a 
          href="/signup" 
          class="inline-flex items-center gap-2 px-6 py-3 bg-white text-navy-700 font-semibold rounded-lg hover:bg-gray-100 transition-colors"
        >
          Sign Up for Free Alerts
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>

      <RelatedArticles currentSlug={slug!} category={displayCategory} />
    </div>
  </article>
</BaseLayout>
