---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import CaseStatusTracker from '../../components/CaseStatusTracker.astro';
import ClaimDetailsSidebar from '../../components/ClaimDetailsSidebar.astro';
import RelatedArticles from '../../components/RelatedArticles.astro';
import { getArticleBySlug } from '../../lib/supabase';
import { siteConfig } from '../../site.config';

import { marked } from 'marked';

const { slug } = Astro.params;
const article = await getArticleBySlug(slug!);

if (!article) {
  return Astro.redirect('/settlements');
}

const publishDate = article.published_at
  ? new Date(article.published_at).toLocaleDateString('en-US', {
      month: 'long',
      day: 'numeric',
      year: 'numeric',
    })
  : null;

const displayCategory = article.category ?? 'Settlement';

// Settlement metadata - extend your Article type or add these fields to Supabase
const meta = {
  status: (article as any).case_status ?? 'filed',
  claimDeadline: (article as any).claim_deadline ?? null,
  claimUrl: (article as any).claim_url ?? null,
  proofRequired: (article as any).proof_required ?? null,
  potentialReward: (article as any).potential_reward ?? null,
  totalAmount: (article as any).settlement_amount ?? null,
  location: (article as any).location ?? null,
  caseName: (article as any).case_name ?? null,
  settlementWebsite: (article as any).settlement_website ?? null,
  claimsAdministrator: (article as any).claims_administrator ?? null,
  classCounsel: (article as any).class_counsel ?? null,
  heroImage: (article as any).hero_image ?? null,
};

const hasSidebarData = meta.claimDeadline || meta.claimUrl || meta.potentialReward || 
                       meta.totalAmount || meta.settlementWebsite;

// SEO structured data
const structuredData = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": article.title,
  "description": article.meta_description,
  "datePublished": article.published_at,
  "dateModified": article.updated_at,
  "publisher": {
    "@type": "Organization",
    "name": siteConfig.name,
    "url": `https://${siteConfig.domain}`
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://${siteConfig.domain}/settlements/${slug}`
  }
};
---

<BaseLayout title={article.title} description={article.meta_description ?? ''}>
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <article class="bg-gray-50 min-h-screen">
    <!-- Hero Header -->
    <header class="bg-gradient-to-br from-navy-700 via-navy-800 to-navy-900 relative overflow-hidden">
      <div class="absolute inset-0 opacity-10">
        <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;0.4&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
      </div>
      
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 lg:py-14 relative">
        <!-- Breadcrumb -->
        <nav class="mb-4">
          <ol class="flex items-center gap-2 text-sm text-white/60">
            <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
            <li><span class="mx-1">/</span></li>
            <li><a href="/settlements" class="hover:text-white transition-colors">Settlements</a></li>
            <li><span class="mx-1">/</span></li>
            <li class="text-white/80 truncate max-w-[200px]">{article.title}</li>
          </ol>
        </nav>

        <!-- Category & Date -->
        <div class="flex flex-wrap items-center gap-3 mb-4">
          <a 
            href={`/category/${displayCategory.toLowerCase().replace(/\s+/g, '-')}`}
            class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-white/20 text-white hover:bg-white/30 transition-colors"
          >
            {displayCategory}
          </a>
          {publishDate && (
            <time class="text-sm text-white/60">{publishDate}</time>
          )}
        </div>

        <!-- Title -->
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-heading font-black text-white leading-tight max-w-4xl">
          {article.title}
        </h1>

        <!-- Subtitle -->
        {article.meta_description && (
          <p class="text-lg lg:text-xl text-white/80 mt-4 leading-relaxed max-w-3xl">
            {article.meta_description}
          </p>
        )}

        <!-- Case Status Tracker -->
        <div class="mt-8 bg-white/10 backdrop-blur-sm rounded-xl p-4 lg:p-6">
          <CaseStatusTracker status={meta.status} />
        </div>
      </div>
    </header>

    <!-- Main Content Area -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 lg:py-12">
      <div class="lg:grid lg:grid-cols-12 lg:gap-10">
        
        <!-- Main Content Column -->
        <main class="lg:col-span-8">
          <!-- Hero Image -->
          {meta.heroImage && (
            <figure class="mb-8 -mt-4 lg:-mt-8">
              <img 
                src={meta.heroImage} 
                alt={article.title}
                class="w-full h-auto rounded-xl shadow-lg object-cover max-h-[400px]"
                loading="eager"
              />
            </figure>
          )}

          <!-- Mobile: Claim Details Card -->
          <div class="lg:hidden mb-8">
            {hasSidebarData && (
              <div class="bg-white rounded-xl shadow-lg border border-gray-100 p-5">
                <div class="flex items-center gap-2 mb-4">
                  <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></span>
                  <span class="font-semibold text-gray-900">Status: {meta.status === 'open' ? 'Open for Claims' : 'In Progress'}</span>
                </div>
                
            {meta.claimUrl && (
                  
                    href={meta.claimUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="block w-full text-center px-5 py-3 bg-green-600 hover:bg-green-700 text-white font-bold rounded-lg transition-colors mb-4"
                  >
                    File a Claim →
                  </a>
                )}
                
                <dl class="grid grid-cols-2 gap-3 text-sm">
                  {meta.claimDeadline && (
                    <div>
                      <dt class="text-gray-500">Deadline</dt>
                      <dd class="font-semibold text-gray-900">{meta.claimDeadline}</dd>
                    </div>
                  )}
                  {meta.potentialReward && (
                    <div>
                      <dt class="text-gray-500">Potential Award</dt>
                      <dd class="font-semibold text-gray-900">{meta.potentialReward}</dd>
                    </div>
                  )}
                  {meta.location && (
                    <div>
                      <dt class="text-gray-500">Location</dt>
                      <dd class="font-semibold text-gray-900">{meta.location}</dd>
                    </div>
                  )}
                </dl>
              </div>
            )}
          </div>

          <!-- Article Body -->
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 sm:p-8 lg:p-10">
            {article.content ? (
<div class="prose-article text-lg" set:html={marked.parse(article.content)} />
            ) : (
              <p class="text-gray-400 italic">Article content is being prepared. Check back soon.</p>
            )}
          </div>

          <!-- Share & Back -->
          <div class="mt-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
            <a href="/settlements" class="inline-flex items-center gap-2 text-navy-600 font-semibold hover:text-navy-800 transition-colors">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18"/>
              </svg>
              Back to Settlements
            </a>
            
            <div class="flex items-center gap-3">
              <span class="text-sm text-gray-500">Share:</span>
              
               <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(article.title)}&url=${encodeURIComponent(`https://${siteConfig.domain}/settlements/${slug}`)}`}
                target="_blank"
                rel="noopener"
                class="w-9 h-9 flex items-center justify-center rounded-full bg-gray-100 text-gray-600 hover:bg-navy-600 hover:text-white transition-colors"
                aria-label="Share on Twitter"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              </a>
              
              <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(`https://${siteConfig.domain}/settlements/${slug}`)}`}
                target="_blank"
                rel="noopener"
                class="w-9 h-9 flex items-center justify-center rounded-full bg-gray-100 text-gray-600 hover:bg-navy-600 hover:text-white transition-colors"
                aria-label="Share on Facebook"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              </a>
              
               <a href={`https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(`https://${siteConfig.domain}/settlements/${slug}`)}&title=${encodeURIComponent(article.title)}`}
                target="_blank"
                rel="noopener"
                class="w-9 h-9 flex items-center justify-center rounded-full bg-gray-100 text-gray-600 hover:bg-navy-600 hover:text-white transition-colors"
                aria-label="Share on LinkedIn"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              </a>
            </div>
          </div>

          <!-- Related Articles -->
          <RelatedArticles currentSlug={slug!} category={displayCategory} />
        </main>

        <!-- Desktop Sidebar -->
        <aside class="hidden lg:block lg:col-span-4">
          <ClaimDetailsSidebar
            status={meta.status === 'open' ? 'Open for Claims' : 'In Progress'}
            claimDeadline={meta.claimDeadline}
            claimUrl={meta.claimUrl}
            proofRequired={meta.proofRequired}
            potentialReward={meta.potentialReward}
            totalAmount={meta.totalAmount}
            location={meta.location}
            caseName={meta.caseName}
            settlementWebsite={meta.settlementWebsite}
            claimsAdministrator={meta.claimsAdministrator}
            classCounsel={meta.classCounsel}
          />
        </aside>
      </div>
    </div>
  </article>
</BaseLayout>
