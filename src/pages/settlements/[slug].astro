---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import CaseStatusTracker from '../../components/CaseStatusTracker.astro';
import SettlementSidebar from '../../components/SettlementSidebar.astro';
import SettlementDataBlock from '../../components/SettlementDataBlock.astro';
import SettlementFAQ from '../../components/SettlementFAQ.astro';
import SimilarSettlements from '../../components/SimilarSettlements.astro';
import CategoryCrossLinks from '../../components/CategoryCrossLinks.astro';
import { getArticleBySlug } from '../../lib/supabase';
import { siteConfig } from '../../site.config';
import { marked } from 'marked';
import { getSettlementArticle } from '../../lib/structured-data';
import { formatDate } from '../../lib/seo-helpers';
import { extractBrand, extractState, toSlug, US_STATES } from '../../lib/brand-state-extraction';

const { slug } = Astro.params;
const article = await getArticleBySlug(slug!);

if (!article) {
  return Astro.redirect('/settlements');
}

const publishDate = article.published_at
  ? new Date(article.published_at).toLocaleDateString('en-US', {
      month: 'long',
      day: 'numeric',
      year: 'numeric',
    })
  : null;

const updatedDate = formatDate(article.updated_at);

const displayCategory = article.category ?? 'Settlement';

const meta = {
  status: article.case_status ?? 'filed',
  claimDeadline: article.claim_deadline ?? null,
  claimUrl: article.claim_url ?? null,
  proofRequired: article.proof_required ?? null,
  potentialReward: article.potential_reward ?? null,
  totalAmount: article.settlement_amount ?? null,
  location: article.location ?? null,
  caseName: article.case_name ?? null,
  settlementWebsite: article.settlement_website ?? null,
  claimsAdministrator: article.claims_administrator ?? null,
  classCounsel: article.class_counsel ?? null,
  heroImage: article.hero_image ?? null,
  heroImageAlt: article.hero_image_alt ?? null,
};

const pageUrl = `https://${siteConfig.domain}/settlements/${slug}`;

const structuredData = getSettlementArticle({ article, pageUrl });

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Settlements', url: '/settlements' },
  { name: article.title, url: `/settlements/${slug}` },
];

// Extract brand & state for contextual linking
const brandName = extractBrand(article);
const brandSlug = brandName ? toSlug(brandName) : null;
const stateSlug = extractState(article);
const stateName = stateSlug ? US_STATES[stateSlug] : null;
---

<BaseLayout title={article.title} description={article.meta_description ?? ''} ogImage={meta.heroImage ?? undefined} breadcrumbs={breadcrumbs}>
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <article class="settlement-page bg-white" data-article-id={article.id}>
    <!-- Header area -->
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-6 pb-2">
      <!-- Breadcrumbs -->
      <nav class="mb-6">
        <ol class="flex items-center gap-1.5 text-sm text-gray-500">
          <li><a href="/" class="hover:text-navy-600 transition-colors">Home</a></li>
          <li><span class="mx-1">&gt;</span></li>
          <li><a href="/settlements" class="hover:text-navy-600 transition-colors">Settlements</a></li>
          <li><span class="mx-1">&gt;</span></li>
          <li class="text-gray-700 truncate max-w-[300px]">{article.title}</li>
        </ol>
      </nav>

      <!-- Title -->
      <h1 class="text-3xl sm:text-4xl lg:text-[2.75rem] font-heading font-black text-gray-900 leading-tight mb-8">
        {article.title}
      </h1>

      <!-- Status Tracker -->
      <div class="mb-8 max-w-3xl mx-auto">
        <CaseStatusTracker status={meta.status} />
      </div>

      <!-- Byline & Category -->
      <div class="flex flex-wrap items-center justify-between gap-4 mb-2">
        <div class="flex flex-wrap items-center gap-2 text-sm text-gray-600">
          <span>By <a href="/about" class="text-blue-600 hover:text-blue-800 transition-colors">Editorial Team</a></span>
          {publishDate && (
            <Fragment>
              <span class="text-gray-300">|</span>
              <time>{publishDate}</time>
            </Fragment>
          )}
          {updatedDate.display && (
            <Fragment>
              <span class="text-gray-300">|</span>
              <time datetime={updatedDate.iso} class="text-gray-500">Updated {updatedDate.display}</time>
            </Fragment>
          )}
        </div>
      </div>

      <div class="mb-4">
        <span class="text-sm font-semibold text-gray-700">Category: </span>
        <a
          href={`/category/${displayCategory.toLowerCase().replace(/\s+/g, '-')}`}
          class="text-sm text-blue-600 hover:text-blue-800 transition-colors"
        >
          {displayCategory}
        </a>
      </div>

      <!-- Divider -->
      <hr class="border-t-[3px] border-gray-900 mb-4" />

      <!-- Social Share Icons -->
      <div class="flex items-center gap-3 mb-6">
        <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(pageUrl)}`}
          target="_blank"
          rel="noopener"
          class="w-9 h-9 flex items-center justify-center rounded-full bg-[#1877F2] text-white hover:opacity-80 transition-opacity"
          aria-label="Share on Facebook"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
        <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(article.title)}&url=${encodeURIComponent(pageUrl)}`}
          target="_blank"
          rel="noopener"
          class="w-9 h-9 flex items-center justify-center rounded-full bg-gray-900 text-white hover:opacity-80 transition-opacity"
          aria-label="Share on X"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a href={`https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(pageUrl)}&title=${encodeURIComponent(article.title)}`}
          target="_blank"
          rel="noopener"
          class="w-9 h-9 flex items-center justify-center rounded-full bg-[#0A66C2] text-white hover:opacity-80 transition-opacity"
          aria-label="Share on LinkedIn"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <a href={`mailto:?subject=${encodeURIComponent(article.title)}&body=${encodeURIComponent(pageUrl)}`}
          class="w-9 h-9 flex items-center justify-center rounded-full bg-gray-500 text-white hover:opacity-80 transition-opacity"
          aria-label="Share via Email"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
        </a>
      </div>
    </div>

    <!-- Main Content Area -->
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">
      <div class="lg:grid lg:grid-cols-12 lg:gap-10">

        <!-- Main Column -->
        <main class="lg:col-span-8">
          <SettlementDataBlock
            caseName={meta.caseName}
            settlementAmount={meta.totalAmount}
            claimDeadline={meta.claimDeadline}
            potentialReward={meta.potentialReward}
            status={meta.status}
            proofRequired={meta.proofRequired}
            location={meta.location}
            claimUrl={meta.claimUrl}
          />

          <!-- Hero Image -->
          {meta.heroImage && (
            <figure class="mb-8">
              <img
                src={meta.heroImage}
                alt={meta.heroImageAlt ?? article.title}
                class="w-full h-auto rounded-lg object-cover max-h-[460px]"
                loading="eager"
              />
            </figure>
          )}

          <!-- Mobile Claim CTA (shown on small screens only) -->
          <div class="lg:hidden mb-8">
            {meta.claimUrl && (
              <a href={meta.claimUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="block w-full text-center px-5 py-3.5 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-lg transition-colors text-lg uppercase tracking-wide"
              >
                Click Here to File a Claim &raquo;
              </a>
            )}
          </div>

          <!-- Article Body -->
          <div class="settlement-article-body">
            {article.content ? (
              <div class="prose-article text-[17px] leading-relaxed" set:html={marked.parse(article.content)} />
            ) : (
              <p class="text-gray-400 italic">Article content is being prepared. Check back soon.</p>
            )}
          </div>

          <!-- Inline Claim Button -->
          {meta.claimUrl && (
            <div class="my-10">
              <h2 class="settlement-detail-heading">Claim Form</h2>
              <a href={meta.claimUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-block px-8 py-3.5 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded transition-colors text-base uppercase tracking-wide"
              >
                Click Here to File a Claim &raquo;
              </a>
              <p class="text-sm text-gray-600 mt-3">
                <strong>NOTE:</strong> If you do not qualify for this settlement do NOT file a claim.
              </p>
            </div>
          )}

          <!-- Settlement Details Section -->
          <div class="settlement-details-section mt-8 space-y-8">
            {meta.claimDeadline && (
              <div>
                <h2 class="settlement-detail-heading">Claim Form Deadline</h2>
                <p class="text-gray-800">{meta.claimDeadline}</p>
              </div>
            )}

            {meta.potentialReward && (
              <div>
                <h2 class="settlement-detail-heading">Potential Award</h2>
                <p class="text-gray-800">{meta.potentialReward}</p>
              </div>
            )}

            {meta.totalAmount && (
              <div>
                <h2 class="settlement-detail-heading">Settlement Amount</h2>
                <p class="text-gray-800">{meta.totalAmount}</p>
              </div>
            )}

            {meta.proofRequired !== null && meta.proofRequired !== undefined && (
              <div>
                <h2 class="settlement-detail-heading">Proof of Purchase</h2>
                <p class="text-gray-800">{meta.proofRequired ? 'Yes - documentation required' : 'No proof required'}</p>
              </div>
            )}

            {meta.location && (
              <div>
                <h2 class="settlement-detail-heading">Location</h2>
                <p class="text-gray-800">{meta.location}</p>
              </div>
            )}

            {meta.caseName && (
              <div>
                <h2 class="settlement-detail-heading">Case Name</h2>
                <p class="text-gray-800">{meta.caseName}</p>
              </div>
            )}

            {meta.settlementWebsite && (
              <div>
                <h2 class="settlement-detail-heading">Settlement Website</h2>
                <p>
                  <a
                    href={meta.settlementWebsite.startsWith('http') ? meta.settlementWebsite : `https://${meta.settlementWebsite}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-blue-600 hover:text-blue-800 transition-colors"
                  >
                    {meta.settlementWebsite.replace(/^https?:\/\//, '')}
                  </a>
                </p>
              </div>
            )}

            {meta.claimsAdministrator && (
              <div>
                <h2 class="settlement-detail-heading">Claims Administrator</h2>
                <p class="text-gray-800 whitespace-pre-line">{meta.claimsAdministrator}</p>
              </div>
            )}

            {meta.classCounsel && (
              <div>
                <h2 class="settlement-detail-heading">Class Counsel</h2>
                <p class="text-gray-800 whitespace-pre-line">{meta.classCounsel}</p>
              </div>
            )}
          </div>

          <SettlementFAQ
            caseName={meta.caseName}
            settlementAmount={meta.totalAmount}
            potentialReward={meta.potentialReward}
            claimDeadline={meta.claimDeadline}
            claimUrl={meta.claimUrl}
            proofRequired={meta.proofRequired}
            title={article.title}
          />

          <SimilarSettlements currentSlug={slug!} category={displayCategory} />

          <CategoryCrossLinks currentCategory={displayCategory} />

          <!-- Contextual links (brand, state, open settlements) -->
          {(brandSlug || stateName) && (
            <div class="mt-8 pt-6 border-t border-gray-200">
              <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-3">Related Pages</h3>
              <div class="flex flex-wrap gap-2">
                {brandSlug && (
                  <a
                    href={`/brand/${brandSlug}`}
                    class="inline-flex items-center gap-1.5 px-4 py-2 bg-gray-100 hover:bg-navy-600 hover:text-white text-gray-700 text-sm font-medium rounded-full transition-colors"
                  >
                    All {brandName} Settlements
                  </a>
                )}
                {stateSlug && stateName && (
                  <a
                    href={`/state/${stateSlug}`}
                    class="inline-flex items-center gap-1.5 px-4 py-2 bg-gray-100 hover:bg-navy-600 hover:text-white text-gray-700 text-sm font-medium rounded-full transition-colors"
                  >
                    {stateName} Settlements
                  </a>
                )}
                <a
                  href="/open-class-action-settlements"
                  class="inline-flex items-center gap-1.5 px-4 py-2 bg-gray-100 hover:bg-navy-600 hover:text-white text-gray-700 text-sm font-medium rounded-full transition-colors"
                >
                  Open Settlements
                </a>
              </div>
            </div>
          )}

          <!-- Back link -->
          <div class="mt-12 pt-8 border-t border-gray-200">
            <a href="/settlements" class="inline-flex items-center gap-2 text-blue-600 font-semibold hover:text-blue-800 transition-colors">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18"/>
              </svg>
              Back to All Settlements
            </a>
          </div>
        </main>

        <!-- Sidebar -->
        <aside class="hidden lg:block lg:col-span-4">
          <SettlementSidebar currentSlug={slug!} category={displayCategory} />
        </aside>
      </div>
    </div>
  </article>
</BaseLayout>
