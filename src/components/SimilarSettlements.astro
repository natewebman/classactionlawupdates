---
import { getArticles, type Article } from '../lib/supabase';
import { sortBySettlementAmount } from '../lib/settlement-amount';

interface Props {
  currentSlug: string;
  category?: string;
  limit?: number;
}

const { currentSlug, category, limit = 4 } = Astro.props;

let settlements: Article[] = [];
try {
  if (category && category !== 'General') {
    const all = await getArticles({ category, limit: limit + 5 });
    const others = all.filter((a) => a.slug !== currentSlug);
    // Sort by settlement amount (largest first), fallback to newest
    const sorted = sortBySettlementAmount(others);
    settlements = sorted.slice(0, limit);
  }
} catch (e) {
  console.error('Error fetching similar settlements:', e);
}
---

{settlements.length > 0 && (
  <section class="mt-10 pt-8 border-t border-gray-200">
    <h2 class="text-2xl font-heading font-bold text-gray-900 mb-6">Similar Settlements</h2>

    <div class="grid gap-4 sm:grid-cols-2">
      {settlements.map((article) => {
        const date = article.published_at
          ? new Date(article.published_at).toLocaleDateString('en-US', {
              month: 'short',
              day: 'numeric',
              year: 'numeric',
            })
          : null;

        return (
          <a
            href={`/settlements/${article.slug}`}
            class="group block bg-gray-50 rounded-lg border border-gray-200 p-4 hover:shadow-md hover:border-gray-300 transition-all"
          >
            <h3 class="font-heading font-bold text-gray-900 leading-snug group-hover:text-navy-600 transition-colors line-clamp-2 mb-2">
              {article.title}
            </h3>
            <div class="flex flex-wrap items-center gap-3 text-sm text-gray-500">
              {article.settlement_amount && (
                <span class="font-semibold text-gray-700">{article.settlement_amount}</span>
              )}
              {date && <time>{date}</time>}
            </div>
          </a>
        );
      })}
    </div>

    {category && category !== 'General' && (
      <div class="mt-4 text-center">
        <a
          href={`/category/${category.toLowerCase().replace(/[\s&\/]+/g, '-').replace(/--+/g, '-')}`}
          class="inline-flex items-center gap-1 text-sm text-navy-600 font-semibold hover:text-navy-800 transition-colors"
        >
          View all {category} settlements
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    )}
  </section>
)}
