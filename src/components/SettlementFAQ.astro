---
import { getFAQPage } from '../lib/structured-data';

interface Props {
  caseName?: string | null;
  settlementAmount?: string | null;
  potentialReward?: string | null;
  claimDeadline?: string | null;
  claimUrl?: string | null;
  proofRequired?: boolean | null;
  title: string;
}

const {
  caseName,
  settlementAmount,
  potentialReward,
  claimDeadline,
  claimUrl,
  proofRequired,
  title,
} = Astro.props;

const displayName = caseName || title;

const deadlineDisplay = claimDeadline
  ? new Date(claimDeadline + 'T00:00:00').toLocaleDateString('en-US', {
      month: 'long',
      day: 'numeric',
      year: 'numeric',
    })
  : null;

// Build FAQ items with hybrid answers: data fields + generic templates
const faqItems: Array<{ question: string; answer: string }> = [];

// Q1: Who qualifies?
faqItems.push({
  question: `Who qualifies for the ${displayName} settlement?`,
  answer: `Eligibility for the ${displayName} settlement depends on the specific terms set by the court. Generally, individuals who were affected by the actions described in the lawsuit during the class period may qualify. Review the full article above for detailed eligibility criteria, or visit the official settlement website for the complete class definition.`,
});

// Q2: How much money?
const rewardText = potentialReward
  ? `Eligible class members may receive ${potentialReward}.`
  : settlementAmount
    ? `The total settlement fund is ${settlementAmount}. Individual payouts will depend on the number of valid claims filed and the specific terms of the settlement.`
    : `The exact payout amount depends on the number of valid claims filed and the terms approved by the court.`;
faqItems.push({
  question: `How much money can I receive from the ${displayName} settlement?`,
  answer: `${rewardText} The final amount per claimant may vary based on the total number of claims submitted.`,
});

// Q3: Deadline
const deadlineText = deadlineDisplay
  ? `The deadline to file a claim is ${deadlineDisplay}. Claims submitted after this date will not be accepted.`
  : `The claim deadline has not yet been announced or may vary. Check the official settlement website for the most current deadline information.`;
faqItems.push({
  question: `What is the deadline to file a claim?`,
  answer: `${deadlineText} We recommend filing as early as possible to ensure your claim is processed.`,
});

// Q4: How to file
const fileText = claimUrl
  ? `You can file a claim online through the official claim form. Click the "File a Claim" button on this page to go directly to the submission form.`
  : `Claim filing instructions will be available once the settlement administrator opens the claims process.`;
const proofText = proofRequired === true
  ? ` You will need to provide documentation or proof of purchase to support your claim.`
  : proofRequired === false
    ? ` No proof of purchase is required to file a claim.`
    : '';
faqItems.push({
  question: `How do I file a claim for the ${displayName} settlement?`,
  answer: `${fileText}${proofText} Be sure to submit your claim before the deadline to be eligible for a payment.`,
});

// Q5: Do I need a lawyer?
faqItems.push({
  question: `Do I need a lawyer to participate in this settlement?`,
  answer: `No, you do not need to hire a lawyer to file a claim in most class action settlements. The class counsel appointed by the court represents all class members. However, if you have questions about your individual rights or want to opt out of the settlement, consulting with an attorney may be helpful.`,
});

const faqSchema = getFAQPage(faqItems);
---

<section class="mt-10 pt-8 border-t border-gray-200">
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <h2 class="text-2xl font-heading font-bold text-gray-900 mb-6">Frequently Asked Questions</h2>

  <div class="space-y-3">
    {faqItems.map((item, i) => (
      <details class="group bg-gray-50 rounded-lg border border-gray-200" open={i === 0}>
        <summary class="flex items-center justify-between cursor-pointer px-5 py-4 text-left font-semibold text-gray-900 hover:text-navy-600 transition-colors select-none">
          <span class="pr-4">{item.question}</span>
          <svg class="w-5 h-5 shrink-0 text-gray-400 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="px-5 pb-4 text-gray-700 leading-relaxed">
          <p>{item.answer}</p>
        </div>
      </details>
    ))}
  </div>
</section>
