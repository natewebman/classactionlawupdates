---
import { siteConfig } from '../site.config';

interface Props {
  currentCategory?: string;
}

const { currentCategory } = Astro.props;

// Normalize the current category slug for comparison
const currentSlug = currentCategory
  ? currentCategory.toLowerCase().replace(/[\s&\/]+/g, '-').replace(/--+/g, '-')
  : '';

const otherCategories = siteConfig.settlementCategories
  .filter((c) => c.slug !== 'all' && c.slug !== currentSlug)
  .slice(0, 4);
---

{otherCategories.length > 0 && (
  <nav class="mt-10 pt-8 border-t border-gray-200">
    <h3 class="text-lg font-heading font-bold text-gray-900 mb-3">You may also be interested in</h3>
    <div class="flex flex-wrap gap-2">
      {otherCategories.map((cat) => (
        <a
          href={`/category/${cat.slug}`}
          class="inline-block px-4 py-2 bg-gray-100 hover:bg-navy-600 hover:text-white text-gray-700 text-sm font-medium rounded-full transition-colors"
        >
          {cat.name}
        </a>
      ))}
    </div>
  </nav>
)}
