---
import { getArticles, type Article } from '../lib/supabase';

interface Props {
  currentSlug: string;
  category?: string;
  limit?: number;
}

const { currentSlug, category, limit = 4 } = Astro.props;

let articles: Article[] = [];
try {
  const allArticles = await getArticles({ 
    category: category && category !== 'General' ? category : undefined,
    limit: limit + 1 
  });
  articles = allArticles.filter(a => a.slug !== currentSlug).slice(0, limit);
} catch (e) {
  console.error('Error fetching related articles:', e);
}
---

{articles.length > 0 && (
  <section class="related-articles mt-12 pt-10 border-t border-gray-200">
    <h2 class="text-2xl font-heading font-bold text-gray-900 mb-6">Related Settlements & News</h2>
    
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {articles.map((article) => {
        const date = article.published_at 
          ? new Date(article.published_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })
          : null;
        const isSettlement = article.category && article.category !== 'General';
        const href = isSettlement ? `/settlements/${article.slug}` : `/news/${article.slug}`;
        
        return (
          <a href={href} class="group block">
            <article class="bg-white rounded-lg border border-gray-200 overflow-hidden hover:shadow-lg transition-shadow h-full flex flex-col">
              <div class="aspect-video bg-gradient-to-br from-navy-100 to-navy-200 relative overflow-hidden">
                <div class="absolute inset-0 flex items-center justify-center">
                  <svg class="w-12 h-12 text-navy-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
                  </svg>
                </div>
              </div>
              
              <div class="p-4 flex-1 flex flex-col">
                {article.category && (
                  <span class="text-xs font-semibold text-navy-600 uppercase tracking-wide mb-1">
                    {article.category}
                  </span>
                )}
                <h3 class="font-heading font-bold text-gray-900 leading-snug group-hover:text-navy-600 transition-colors line-clamp-3 flex-1">
                  {article.title}
                </h3>
                {date && (
                  <time class="text-xs text-gray-500 mt-2">{date}</time>
                )}
              </div>
            </article>
          </a>
        );
      })}
    </div>
  </section>
)}
