---
import { siteConfig } from '../site.config';
---

<section class="relative min-h-[520px] flex items-center">
  <!-- Background image with overlay -->
  <div class="absolute inset-0 bg-navy-700">
    <!-- Decorative geometric pattern instead of stock photo -->
    <div class="absolute inset-0 opacity-10">
      <svg class="w-full h-full" preserveAspectRatio="none" viewBox="0 0 1200 600">
        <defs>
          <pattern id="grid" width="60" height="60" patternUnits="userSpaceOnUse">
            <path d="M 60 0 L 0 0 0 60" fill="none" stroke="white" stroke-width="0.5"/>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#grid)"/>
        <circle cx="900" cy="300" r="250" fill="white" opacity="0.05"/>
        <circle cx="150" cy="100" r="120" fill="white" opacity="0.03"/>
      </svg>
    </div>
    <div class="absolute inset-0 bg-gradient-to-r from-navy-900/80 via-navy-800/60 to-navy-700/40"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
    <div class="max-w-2xl">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-heading font-black text-white leading-tight mb-6">
        Class Action News &amp; Settlements
      </h1>
      <p class="text-lg sm:text-xl text-white/80 mb-10 leading-relaxed">
        {siteConfig.tagline} Billions of dollars are claimed every year.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="/settlements" class="btn-primary text-base px-8 py-4">
          Browse Settlements
          <svg class="w-5 h-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
        <a href="/signup" class="btn-outline text-base px-8 py-4">
          Join for Free Alerts
        </a>
      </div>
    </div>
  </div>
</section>
