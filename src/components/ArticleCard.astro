---
interface Props {
  title: string;
  slug: string;
  category?: string | null;
  newsType?: string | null;
  metaDescription?: string | null;
  publishedAt?: string | null;
  heroImage?: string | null;
  heroImageAlt?: string | null;
  /** Base URL path: "/news" or "/settlements" */
  basePath?: string;
  /** Show as featured (larger) card */
  featured?: boolean;
}

const {
  title,
  slug,
  category,
  newsType,
  metaDescription,
  publishedAt,
  heroImage,
  heroImageAlt,
  basePath = '/news',
  featured = false,
} = Astro.props;

const href = `${basePath}/${slug}`;
const displayCategory = category ?? newsType ?? 'General';
const date = publishedAt ? new Date(publishedAt).toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
}) : null;

// Generate a deterministic color based on category name
const categoryColors: Record<string, string> = {
  'stocks': 'bg-emerald-100 text-emerald-800',
  'personal-injury': 'bg-red-100 text-red-800',
  'product-recalls': 'bg-amber-100 text-amber-800',
  'drugs-pharmacy': 'bg-purple-100 text-purple-800',
  'financial': 'bg-blue-100 text-blue-800',
  'online-privacy': 'bg-cyan-100 text-cyan-800',
  'case-filings': 'bg-orange-100 text-orange-800',
  'settlement-news': 'bg-green-100 text-green-800',
};
const colorClass = categoryColors[category?.toLowerCase().replace(/[\s&]/g, '-') ?? ''] ?? 'bg-gray-100 text-gray-700';
---

<a
  href={href}
  class:list={[
    'article-card block bg-white rounded-xl border border-gray-100 overflow-hidden',
    featured ? 'lg:flex lg:items-stretch' : '',
  ]}
>
  <!-- Image area – show hero image or gradient placeholder -->
  <div
    class:list={[
      'relative overflow-hidden',
      featured ? 'lg:w-1/2 h-48 lg:h-auto' : 'h-44',
      !heroImage ? 'bg-gradient-to-br from-navy-600 to-navy-800' : '',
    ]}
  >
    {heroImage ? (
      <img
        src={heroImage}
        alt={heroImageAlt ?? title}
        class="w-full h-full object-cover"
        loading="lazy"
      />
    ) : (
      <div class="absolute inset-0 flex items-center justify-center opacity-20">
        <svg class="w-16 h-16 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
            d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
        </svg>
      </div>
    )}
    <!-- Category badge -->
    <div class="absolute top-3 left-3">
      <span class={`inline-block px-2.5 py-1 rounded-full text-xs font-semibold ${colorClass}`}>
        {displayCategory}
      </span>
    </div>
  </div>

  <!-- Content -->
  <div class:list={['p-5', featured ? 'lg:w-1/2 lg:p-8 lg:flex lg:flex-col lg:justify-center' : '']}>
    {date && (
      <time class="text-xs text-gray-400 uppercase tracking-wide font-medium">{date}</time>
    )}
    <h3
      class:list={[
        'font-heading font-bold text-gray-900 mt-1 leading-snug',
        featured ? 'text-xl lg:text-2xl' : 'text-base',
      ]}
    >
      {title}
    </h3>
    {metaDescription && (
      <p class:list={['text-gray-500 mt-2 line-clamp-2', featured ? 'text-base' : 'text-sm']}>
        {metaDescription}
      </p>
    )}
    <span class="inline-flex items-center gap-1 text-navy-600 text-sm font-semibold mt-3">
      Read more<span class="sr-only"> about {title}</span>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
      </svg>
    </span>
  </div>
</a>
