---
interface Props {
  caseName?: string | null;
  settlementAmount?: string | null;
  claimDeadline?: string | null;
  potentialReward?: string | null;
  status?: string;
  proofRequired?: boolean | null;
  location?: string | null;
  claimUrl?: string | null;
}

const {
  caseName,
  settlementAmount,
  claimDeadline,
  potentialReward,
  status = 'filed',
  proofRequired,
  location,
  claimUrl,
} = Astro.props;

const statusLabels: Record<string, string> = {
  filed: 'Filed',
  pending: 'Pending Approval',
  settled: 'Settled',
  approved: 'Open for Claims',
  paying: 'Distributing Payments',
  closed: 'Closed',
  open: 'Open for Claims',
};

// Derive closed state from claim deadline
const isClosed = (() => {
  if (!claimDeadline) return false;
  const now = new Date();
  now.setHours(0, 0, 0, 0);
  const deadline = new Date(claimDeadline + 'T00:00:00');
  return deadline.getTime() < now.getTime();
})();

const effectiveStatus = isClosed ? 'closed' : status;
const statusLabel = isClosed ? 'Closed' : (statusLabels[status] ?? status);

const statusColors: Record<string, string> = {
  filed: 'bg-yellow-100 text-yellow-800',
  pending: 'bg-yellow-100 text-yellow-800',
  settled: 'bg-blue-100 text-blue-800',
  approved: 'bg-green-100 text-green-800',
  paying: 'bg-green-100 text-green-800',
  open: 'bg-green-100 text-green-800',
  closed: 'bg-red-100 text-red-800',
};

const statusColor = statusColors[effectiveStatus] ?? 'bg-gray-100 text-gray-600';

const deadlineDisplay = claimDeadline
  ? new Date(claimDeadline + 'T00:00:00').toLocaleDateString('en-US', {
      month: 'long',
      day: 'numeric',
      year: 'numeric',
    })
  : null;

// Deadline proximity logic
let deadlineBadge: { text: string; classes: string } | null = null;
if (claimDeadline) {
  const now = new Date();
  now.setHours(0, 0, 0, 0);
  const deadline = new Date(claimDeadline + 'T00:00:00');
  const daysUntil = Math.ceil((deadline.getTime() - now.getTime()) / (1000 * 60 * 60 * 24));
  if (daysUntil < 0) {
    deadlineBadge = { text: 'Claim Deadline Passed', classes: 'bg-red-100 text-red-800' };
  } else if (daysUntil <= 30) {
    deadlineBadge = { text: 'Claim Deadline Approaching', classes: 'bg-amber-100 text-amber-800' };
  }
}

const hasData = caseName || settlementAmount || claimDeadline || potentialReward || location || proofRequired !== null;
---

{hasData && (
  <div class="bg-gray-50 border border-gray-200 rounded-xl p-5 sm:p-6 mb-8">
    {deadlineBadge && (
      <div class={`inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-bold mb-4 ${deadlineBadge.classes}`}>
        <span>{deadlineBadge.text}</span>
      </div>
    )}
    <div class="grid grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5">
      {caseName && (
        <div class="col-span-2 lg:col-span-3">
          <span class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Case Name</span>
          <span class="text-base font-bold text-gray-900">{caseName}</span>
        </div>
      )}

      {settlementAmount && (
        <div>
          <span class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Settlement Amount</span>
          <span class="text-base font-bold text-gray-900">{settlementAmount}</span>
        </div>
      )}

      {deadlineDisplay && (
        <div>
          <span class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Claim Deadline</span>
          <time datetime={claimDeadline!} class="text-base font-bold text-gray-900">{deadlineDisplay}</time>
        </div>
      )}

      {potentialReward && (
        <div>
          <span class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Potential Reward</span>
          <span class="text-base font-bold text-gray-900">{potentialReward}</span>
        </div>
      )}

      <div>
        <span class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Status</span>
        <span class={`inline-block px-2.5 py-0.5 rounded-full text-xs font-bold ${statusColor}`}>
          {statusLabel}
        </span>
      </div>

      {proofRequired !== null && proofRequired !== undefined && (
        <div>
          <span class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Proof Required</span>
          <span class="text-base font-bold text-gray-900">{proofRequired ? 'Yes' : 'No'}</span>
        </div>
      )}

      {location && (
        <div>
          <span class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Location</span>
          <span class="text-base font-bold text-gray-900">{location}</span>
        </div>
      )}
    </div>

    {isClosed ? (
      <div class="mt-5 pt-4 border-t border-gray-200">
        <p class="text-sm text-gray-600 mb-3">This settlement is closed. Sign up to get notified about future settlements.</p>
        <a
          href="/signup"
          class="inline-flex items-center gap-2 px-6 py-3 bg-emerald-600 hover:bg-emerald-700 text-white font-bold rounded-lg transition-colors text-sm uppercase tracking-wide"
        >
          Sign Up for Alerts
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
        </a>
      </div>
    ) : claimUrl ? (
      <div class="mt-5 pt-4 border-t border-gray-200">
        <a
          href={claimUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-lg transition-colors text-sm uppercase tracking-wide"
        >
          File a Claim
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
          </svg>
        </a>
      </div>
    ) : null}
  </div>
)}
