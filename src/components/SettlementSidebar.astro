---
import { getArticles, type Article } from '../lib/supabase';

interface Props {
  currentSlug: string;
  category?: string;
}

const { currentSlug, category } = Astro.props;

let relatedArticles: Article[] = [];
try {
  const allArticles = await getArticles({
    category: category && category !== 'General' ? category : undefined,
    limit: 5,
  });
  relatedArticles = allArticles.filter((a) => a.slug !== currentSlug).slice(0, 3);
} catch (e) {
  console.error('Error fetching related articles:', e);
}
---

<div class="settlement-sidebar space-y-8 sticky top-24">
  <!-- Newsletter Signup -->
  <div class="bg-gray-100 rounded-lg p-6">
    <h3 class="text-lg font-heading font-black text-gray-900 uppercase tracking-wide mb-3">
      Get Our Newsletter
    </h3>
    <p class="text-sm text-gray-700 mb-4 leading-relaxed">
      We tell you about <strong class="text-blue-600">cash</strong> you can <strong class="text-blue-600">claim</strong> every week! Subscribe to our free newsletter today.
    </p>
    <a
      href="/signup"
      class="block w-full text-center px-5 py-3 bg-navy-600 hover:bg-navy-700 text-white font-semibold rounded-lg transition-colors text-sm"
    >
      Subscribe Now
    </a>
  </div>

  <!-- Related Settlements -->
  {relatedArticles.length > 0 && (
    <div class="space-y-6">
      {relatedArticles.map((article) => {
        const date = article.published_at
          ? new Date(article.published_at).toLocaleDateString('en-US', {
              month: 'long',
              day: 'numeric',
              year: 'numeric',
            }).toUpperCase()
          : null;
        const isSettlement = article.category && article.category !== 'General';
        const href = isSettlement ? `/settlements/${article.slug}` : `/news/${article.slug}`;

        return (
          <div class="group">
            <div class="aspect-[16/9] bg-gradient-to-br from-navy-100 to-navy-200 rounded-lg overflow-hidden mb-3 relative">
              {article.hero_image ? (
                <img
                  src={article.hero_image}
                  alt={article.hero_image_alt ?? article.title}
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
              ) : (
                <div class="absolute inset-0 flex items-center justify-center">
                  <svg class="w-10 h-10 text-navy-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
                  </svg>
                </div>
              )}
            </div>
            <a href={href} class="block">
              <h4 class="font-heading font-bold text-gray-900 leading-snug group-hover:text-blue-600 transition-colors mb-1">
                {article.title}
              </h4>
            </a>
            <div class="flex items-center gap-2 text-xs text-gray-500 uppercase tracking-wide mb-2">
              {date && <time>{date}</time>}
              {date && article.category && <span>|</span>}
              {article.category && <span>{article.category}</span>}
            </div>
            <a href={href} class="inline-flex items-center gap-1.5 text-sm font-bold text-navy-700 hover:text-blue-600 transition-colors uppercase tracking-wide">
              Read more about {article.title}
              <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
              </svg>
            </a>
          </div>
        );
      })}
    </div>
  )}
</div>
